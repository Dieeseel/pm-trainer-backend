generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId Int      @unique 
  first_name String?  @map("firstName")
  last_name  String?  @map("lasttName")
  username   String? 
  photo_url  String? 
}
